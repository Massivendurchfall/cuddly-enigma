local function clearWorldTable(tbl)
    for key, _ in pairs(tbl) do
        clearWorldRec(tbl, key)
    end
end

local function tokenContainerFromPart(part)
    local top = part
    local limit = 0
    while top and top.Parent and top.Parent ~= tokensFolder and limit < 10 do
        top = top.Parent
        limit += 1
    end
    return top or part
end

local function buildCoinESPFromPart(part)
    local container = tokenContainerFromPart(part)
    if not container then return end
    if coinRecords[container] then return end
    local anchor = part
    local rec = { inst = container, anchor = anchor, dirty = true }
    coinRecords[container] = rec
    rec.highlight = ensureHighlightOn(container, "ESP_Highlight")
    rec.billboard, rec.textlabel = ensureBillboard(container, anchor, "ESP_Name")
    ensureBox(rec)
    rec.ancestry = container.AncestryChanged:Connect(function(_, parent)
        if not parent then clearWorldRec(coinRecords, container) end
    end)
end

local function buildPumpkinESPFromModel(pickupModel)
    if pumpkinRecords[pickupModel] then return end
    local hrp = pickupModel:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    local rec = { inst = pickupModel, anchor = hrp, dirty = true }
    pumpkinRecords[pickupModel] = rec
    rec.highlight = ensureHighlightOn(pickupModel, "ESP_Highlight")
    rec.billboard, rec.textlabel = ensureBillboard(pickupModel, hrp, "ESP_Name")
    ensureBox(rec)
    rec.ancestry = pickupModel.AncestryChanged:Connect(function(_, parent)
        if not parent then clearWorldRec(pumpkinRecords, pickupModel) end
    end)
end

local function refreshAllCoinsInitial()
    if not tokensFolder then return end
    for _, d in ipairs(tokensFolder:GetDescendants()) do
        if d:IsA("TouchTransmitter") or d.Name == "TouchInterest" then
            local p = d.Parent
            if p and p:IsA("BasePart") then
                buildCoinESPFromPart(p)
            end
        end
    end
end

local function refreshAllPumpkinsInitial()
    if not pumpkinsFolder then return end
    for _, spawn in ipairs(pumpkinsFolder:GetDescendants()) do
        if spawn:IsA("Model") and spawn.Name == "PumpkinPickUp" then
            buildPumpkinESPFromModel(spawn)
        end
        if spawn:IsA("BasePart") and spawn.Name == "HumanoidRootPart" then
            local pick = spawn:FindFirstAncestor("PumpkinPickUp")
            if pick then buildPumpkinESPFromModel(pick) end
        end
    end
end

local function applyWorldVisual(rec, labelText, col, isModel, modelOrPart)
    if rec.highlight then
        rec.highlight.Enabled = worldShowChams
        rec.highlight.FillColor = col
        rec.highlight.OutlineColor = col
        rec.highlight.Adornee = rec.inst
    end
    if rec.billboard and rec.textlabel then
        rec.billboard.Enabled = worldShowNames
        rec.billboard.Adornee = rec.anchor
        rec.textlabel.Text = labelText
        rec.textlabel.TextColor3 = col
        rec.textlabel.TextScaled = false
        rec.textlabel.TextSize = 16
    end
    if worldShowBoxes then
        if isModel then
            updateBoxFromModel(rec, modelOrPart, col)
        else
            local dummy = { boxFrame = rec.boxFrame, boxStroke = rec.boxStroke }
            dummy.boxFrame = rec.boxFrame
            dummy.boxStroke = rec.boxStroke
            updateBoxFromModel(rec, rec.inst, col)
        end
    else
        hideBox(rec)
    end
end

