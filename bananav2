local function findBananaModel(container)
    if container:IsA("Model") then return container end
    local m = container:FindFirstChild("banana1") or container:FindFirstChild("Base")
    if m and m:IsA("Model") then return m end
    local candidate = container:FindFirstChildWhichIsA("Model", true)
    if candidate then return candidate end
    return nil
end

local function findBananaAnchor(model)
    local head = model:FindFirstChild("Head", true)
    local root = model:FindFirstChild("HumanoidRootPart", true) or model:FindFirstChild("Root", true) or model:FindFirstChild("RootBase", true)
    local base = model:FindFirstChild("Base", true)
    local any = model:FindFirstChildWhichIsA("BasePart", true)
    return head or root or base or any
end

local bananasFolder
local bananasAddedConn, bananasRemovedConn, bananasDescAddedConn

local function labelForBananaContainer(container)
    if container.Name == "LobbyBananaAI" or string.find(string.lower(container.Name), "ai") then
        return "BananaAI"
    end
    local plr = Players:FindFirstChild(container.Name)
    if plr then return plr.Name end
    return container.Name
end

local function bananaBuild(container)
    local model = findBananaModel(container)
    if not model then return end
    local anchor = findBananaAnchor(model)
    if not anchor then return end
    local rec = bananaRecords[container]
    if not rec then
        rec = { container = container, dirty = true }
        bananaRecords[container] = rec
    end
    rec.model = model
    rec.anchor = anchor
    rec.label = labelForBananaContainer(container)
    ensureSingleChild(model, "ESP_Banana_Name")
    rec.highlight = ensureHighlightOn(model, "ESP_Banana_Highlight")
    rec.billboard, rec.textlabel = ensureBillboard(model, anchor, "ESP_Banana_Name")
    ensureBox(rec)
    rec.dirty = true
end

local function bananaClear(container)
    local rec = bananaRecords[container]
    if not rec then return end
    if rec.highlight and rec.highlight.Parent then rec.highlight:Destroy() end
    if rec.billboard and rec.billboard.Parent then rec.billboard:Destroy() end
    destroyBox(rec)
    bananaRecords[container] = nil
end

local function bananaUpdate(rec)
    local col = killerColor
    if rec.highlight then
        rec.highlight.Enabled = espEnabled and showChams
        rec.highlight.FillColor = col
        rec.highlight.OutlineColor = col
        rec.highlight.Adornee = rec.model
    end
    if rec.billboard and rec.textlabel then
        rec.billboard.Enabled = espEnabled and showNames
        rec.billboard.Adornee = rec.anchor
        rec.textlabel.Text = rec.label or "BananaAI"
        rec.textlabel.TextColor3 = col
        rec.textlabel.TextScaled = false
        rec.textlabel.TextSize = 16
    end
    updateBoxFromModel(rec, rec.model, col)
    rec.dirty = false
end

local function hookBananasFolder(folder)
    if bananasAddedConn then bananasAddedConn:Disconnect() bananasAddedConn = nil end
    if bananasRemovedConn then bananasRemovedConn:Disconnect() bananasRemovedConn = nil end
    if bananasDescAddedConn then bananasDescAddedConn:Disconnect() bananasDescAddedConn = nil end
    bananasFolder = folder
    bananasAddedConn = folder.ChildAdded:Connect(function(ch) bananaBuild(ch) end)
    bananasRemovedConn = folder.ChildRemoved:Connect(function(ch) bananaClear(ch) end)
    bananasDescAddedConn = folder.DescendantAdded:Connect(function(_) for _, rec in pairs(bananaRecords) do rec.dirty = true end end)
    for _, child in ipairs(folder:GetChildren()) do bananaBuild(child) end
end

local function ensureBananasWatchers()
    local gb = Workspace:FindFirstChild("GameBananas")
    if gb then
        hookBananasFolder(gb)
    else
        Workspace.ChildAdded:Connect(function(ch)
            if ch.Name == "GameBananas" then
                hookBananasFolder(ch)
            end
        end)
    end
end

ensureBananasWatchers()

RunService.RenderStepped:Connect(function()
    if not espEnabled then
        for _, rec in pairs(records) do
            if rec.highlight then rec.highlight.Enabled = false end
            if rec.billboard then rec.billboard.Enabled = false end
            hideBox(rec)
        end
        for _, rec in pairs(bananaRecords) do
            if rec.highlight then rec.highlight.Enabled = false end
            if rec.billboard then rec.billboard.Enabled = false end
            hideBox(rec)
        end
        return
    end
    for _, rec in pairs(records) do
        if rec.plr and rec.plr.Parent and rec.char and rec.char.Parent then
            if rec.dirty then updateRecord(rec) else
                local r = roleForPlayer(rec.plr)
                updateBoxFromModel(rec, rec.char, colorForRole(r))
            end
        else
            if rec.plr then clearESPFor(rec.plr) end
        end
    end
    for container, rec in pairs(bananaRecords) do
        if container and container.Parent and rec.model and rec.model.Parent then
            if rec.dirty then bananaUpdate(rec) else
                updateBoxFromModel(rec, rec.model, killerColor)
            end
        else
            bananaClear(container)
        end
    end
end)

