local removeFog = true
local function applyFogSetting()
    if removeFog then
        Lighting.FogStart = 0
        Lighting.FogEnd = 1e10
        local atmo = Lighting:FindFirstChildOfClass("Atmosphere")
        if atmo then
            atmo.Density = 0
            atmo.Haze = 0
            atmo.Glare = 0
            atmo.Offset = 0
        end
    end
end

VisualsTab:CreateToggle({
    Name = "Remove Fog",
    CurrentValue = true,
    Flag = "RemoveFog",
    Callback = function(v)
        removeFog = v
        if v then applyFogSetting() end
    end
})

Lighting.ChildAdded:Connect(function(ch)
    if removeFog and ch:IsA("Atmosphere") then
        task.defer(applyFogSetting)
    end
end)

