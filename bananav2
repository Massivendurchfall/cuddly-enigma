end

local function disconnectPumpkins()
    if pumpkinsConn then pumpkinsConn:Disconnect() pumpkinsConn = nil end
end

local function purgePeels()
    if not peelsFolder then return end
    for _, obj in ipairs(peelsFolder:GetChildren()) do pcall(function() obj:Destroy() end) end
end

local function touchPart(part)
    if not character then return end
    local hrp = character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    pcall(function()
        firetouchinterest(hrp, part, 0)
        task.wait()
        firetouchinterest(hrp, part, 1)
    end)
end

local function collectAllTokens()
    if not tokensFolder then return end
    for _, d in ipairs(tokensFolder:GetDescendants()) do
        if d:IsA("TouchTransmitter") or d.Name == "TouchInterest" then
            local part = d.Parent
            if part and part:IsA("BasePart") then
                touchPart(part)
            end
        end
    end
end

local function pumpkinPartFromDescendant(desc)
    if desc:IsA("TouchTransmitter") or desc.Name == "TouchInterest" then
        local part = desc.Parent
        if part and part:IsA("BasePart") and part.Name == "HumanoidRootPart" then
            if part:FindFirstAncestor("PumpkinPickUp") then
                return part
            end
        end
    end
    return nil
end

local function collectAllPumpkins()
    if not pumpkinsFolder then return end
    for _, d in ipairs(pumpkinsFolder:GetDescendants()) do
        local p = pumpkinPartFromDescendant(d)
        if p then touchPart(p) end
    end
end

