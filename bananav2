local function applyWalkSpeed()
    if humanoid and humanoid.WalkSpeed ~= targetSpeed then
        humanoid.WalkSpeed = targetSpeed
    end
end

local function onHumanoidSpeedChanged()
    if humanoid and humanoid.WalkSpeed ~= targetSpeed then
        humanoid.WalkSpeed = targetSpeed
    end
end

local function setCharacter(c)
    character = c
    originalCollide = {}
    if noclipConn then noclipConn:Disconnect() noclipConn = nil end
    humanoid = c:FindFirstChildOfClass("Humanoid") or c:WaitForChild("Humanoid", 10)
    if humanoid then
        applyWalkSpeed()
        humanoid:GetPropertyChangedSignal("WalkSpeed"):Connect(onHumanoidSpeedChanged)
    end
    if noclipEnabled then
        for _, v in ipairs(c:GetDescendants()) do
            if v:IsA("BasePart") then
                if originalCollide[v] == nil then originalCollide[v] = v.CanCollide end
                v.CanCollide = false
            end
        end
        noclipConn = c.DescendantAdded:Connect(function(d)
            if noclipEnabled and d:IsA("BasePart") then
                if originalCollide[d] == nil then originalCollide[d] = d.CanCollide end
                d.CanCollide = false
            end
        end)
    end
end

