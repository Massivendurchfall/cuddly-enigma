AutoTab:CreateToggle({
    Name = "AutoCollectCoins",
    CurrentValue = false,
    Flag = "AutoCollectCoins",
    Callback = function(v)
        autoCollectCoins = v
        if not v then
            disconnectTokens()
            return
        end
        tokensFolder = findTokens()
        if tokensFolder then
            collectAllTokens()
            disconnectTokens()
            tokenAddedConn = tokensFolder.DescendantAdded:Connect(function(desc)
                if not autoCollectCoins then return end
                if desc:IsA("TouchTransmitter") or desc.Name == "TouchInterest" then
                    local part = desc.Parent
                    if part and part:IsA("BasePart") then
                        task.defer(function()
                            if autoCollectCoins then touchPart(part) end
                        end)
                    end
                end
            end)
        end
    end
})

AutoTab:CreateToggle({
    Name = "AutoCollectPumpkins",
    CurrentValue = false,
    Flag = "AutoCollectPumpkins",
    Callback = function(v)
        autoCollectPumpkins = v
        if not v then
            disconnectPumpkins()
            return
        end
        pumpkinsFolder = findPumpkins()
        if pumpkinsFolder then
            collectAllPumpkins()
            disconnectPumpkins()
            pumpkinsConn = pumpkinsFolder.DescendantAdded:Connect(function(desc)
                if not autoCollectPumpkins then return end
                local part = pumpkinPartFromDescendant(desc)
                if part then
                    task.defer(function()
                        if autoCollectPumpkins then touchPart(part) end
                    end)
                end
            end)
        end
    end
})

