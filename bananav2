local function ensureSingleChild(parent, name)
    local found = nil
    for _, ch in ipairs(parent:GetChildren()) do
        if ch.Name == name then
            if not found then
                found = ch
            else
                ch:Destroy()
            end
        end
    end
    return found
end

local function ensureHighlightOn(target, name)
    local existing = ensureSingleChild(target, name or "ESP_Highlight")
    local h = existing
    if not h or not h:IsA("Highlight") then
        if h then h:Destroy() end
        h = Instance.new("Highlight")
        h.Name = name or "ESP_Highlight"
        h.FillTransparency = 0.3
        h.OutlineTransparency = 0
        h.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
        h.Parent = target
    end
    h.Adornee = target
    return h
end

local function ensureBillboard(parent, adornee, name)
    local existing = ensureSingleChild(parent, name or "ESP_Name")
    local bb = existing
    if not bb or not bb:IsA("BillboardGui") then
        if bb then bb:Destroy() end
        bb = Instance.new("BillboardGui")
        bb.Name = name or "ESP_Name"
        bb.Size = UDim2.new(0, 140, 0, 22)
        bb.StudsOffset = Vector3.new(0, 2.5, 0)
        bb.AlwaysOnTop = true
        bb.Adornee = adornee
        bb.Parent = parent
        local tl = Instance.new("TextLabel")
        tl.Name = "Text"
        tl.Size = UDim2.new(1, 0, 1, 0)
        tl.BackgroundTransparency = 1
        tl.TextScaled = false
        tl.TextSize = 16
        tl.Font = Enum.Font.SourceSansBold
        tl.Parent = bb
    else
        bb.Adornee = adornee
        local tl = bb:FindFirstChild("Text")
        if tl then
            tl.TextScaled = false
            tl.TextSize = 16
        end
    end
    return bb, bb:FindFirstChild("Text")
end

local function ensureBox(rec)
    if rec.boxFrame then return end
    local f = Instance.new("Frame")
    f.Name = "ESP_Box"
    f.AnchorPoint = Vector2.new(0.5, 0.5)
    f.BackgroundTransparency = 1
    f.Visible = false
    f.Parent = screenGui
    local s = Instance.new("UIStroke")
    s.Thickness = 2
    s.Parent = f
    rec.boxFrame = f
    rec.boxStroke = s
end

local function hideBox(rec)
    if rec and rec.boxFrame then rec.boxFrame.Visible = false end
end

local function destroyBox(rec)
    if rec and rec.boxFrame then rec.boxFrame:Destroy() rec.boxFrame = nil rec.boxStroke = nil end
end

local function updateBoxFromModel(rec, model, col)
    if not showBoxes or not espEnabled or not model then
        hideBox(rec)
        return
    end
    local cf, size = model:GetBoundingBox()
    local sx, sy, sz = size.X/2, size.Y/2, size.Z/2
    local corners = {
        Vector3.new(-sx, -sy, -sz), Vector3.new(-sx, -sy, sz),
        Vector3.new(-sx, sy, -sz),  Vector3.new(-sx, sy, sz),
        Vector3.new(sx, -sy, -sz),  Vector3.new(sx, -sy, sz),
        Vector3.new(sx, sy, -sz),   Vector3.new(sx, sy, sz)
    }
    local minX, minY = math.huge, math.huge
    local maxX, maxY = -math.huge, -math.huge
    local anyFront = false
    for _, v in ipairs(corners) do
        local wp = (cf * CFrame.new(v)).Position
        local vp = Camera:WorldToViewportPoint(wp)
        if vp.Z > 0 then anyFront = true end
        if vp.X < minX then minX = vp.X end
        if vp.X > maxX then maxX = vp.X end
        if vp.Y < minY then minY = vp.Y end
        if vp.Y > maxY then maxY = vp.Y end
    end
    if not anyFront then
        hideBox(rec)
        return
    end
    ensureBox(rec)
    local w = math.max(2, maxX - minX)
    local h = math.max(2, maxY - minY)
    local cx = minX + w/2
    local cy = minY + h/2
    rec.boxFrame.Visible = true
    rec.boxFrame.Position = UDim2.fromOffset(cx, cy)
    rec.boxFrame.Size = UDim2.fromOffset(w, h)
    rec.boxStroke.Color = col
end

local function ensureConnections(plr, rec)
    if rec.teamConn then rec.teamConn:Disconnect() rec.teamConn = nil end
    if rec.attrConn then rec.attrConn:Disconnect() rec.attrConn = nil end
    rec.teamConn = plr:GetPropertyChangedSignal("Team"):Connect(function()
        rec.dirty = true
    end)
    if plr.GetAttributeChangedSignal then
        rec.attrConn = plr:GetAttributeChangedSignal("Role"):Connect(function()
            rec.dirty = true
        end)
    end
end

local function buildESPForCharacter(plr, char)
    local hrp = char:FindFirstChild("HumanoidRootPart") or char:WaitForChild("HumanoidRootPart", 8)
    if not hrp then return end
    local head = char:FindFirstChild("Head") or char:WaitForChild("Head", 8) or hrp
    local rec = records[plr]
    if not rec then
        rec = { dirty = true }
        records[plr] = rec
        ensureConnections(plr, rec)
    end
    rec.char = char
    rec.plr = plr
    rec.head = head
    rec.hrp = hrp
    rec.highlight = ensureHighlightOn(char, "ESP_Highlight")
    rec.billboard, rec.textlabel = ensureBillboard(char, head, "ESP_Name")
    ensureBox(rec)
    rec.dirty = true
end

local function ensureESPFor(plr)
    if plr == LocalPlayer then return end
    task.spawn(function()
        local char = plr.Character or plr.CharacterAdded:Wait()
        if not char then return end
        buildESPForCharacter(plr, char)
    end)
end

local function clearESPFor(plr)
    local rec = records[plr]
    if not rec then return end
    if rec.teamConn then rec.teamConn:Disconnect() rec.teamConn = nil end
    if rec.attrConn then rec.attrConn:Disconnect() rec.attrConn = nil end
    if rec.highlight and rec.highlight.Parent then rec.highlight:Destroy() end
    if rec.billboard and rec.billboard.Parent then rec.billboard:Destroy() end
    destroyBox(rec)
    records[plr] = nil
end

local function updateRecord(rec)
    local r = roleForPlayer(rec.plr)
    local col = colorForRole(r)
    if rec.highlight then
        rec.highlight.Enabled = espEnabled and showChams
        rec.highlight.FillColor = col
        rec.highlight.OutlineColor = col
        rec.highlight.Adornee = rec.char
    end
    if rec.billboard and rec.textlabel then
        if r == "Killer" then
            rec.billboard.Enabled = false
        else
            rec.billboard.Enabled = espEnabled and showNames
            rec.billboard.Adornee = rec.head or rec.hrp
            if r == "Survivor" then
                rec.textlabel.Text = "[Survivor] " .. rec.plr.Name
            else
                rec.textlabel.Text = rec.plr.Name
            end
            rec.textlabel.TextColor3 = col
            rec.textlabel.TextScaled = false
            rec.textlabel.TextSize = 16
        end
    end
    updateBoxFromModel(rec, rec.char, col)
    rec.dirty = false
end

