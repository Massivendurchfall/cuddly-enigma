local function roleForPlayer(plr)
    local tn = plr.Team and plr.Team.Name or ""
    local s = string.lower(tn)
    if string.find(s, "banana") or string.find(s, "killer") then return "Killer" end
    if string.find(s, "survivor") then return "Survivor" end
    local attr = plr:GetAttribute("Role")
    if typeof(attr) == "string" then
        local a = string.lower(attr)
        if string.find(a, "banana") or string.find(a, "killer") then return "Killer" end
        if string.find(a, "survivor") then return "Survivor" end
    end
    return nil
end

local function colorForRole(r)
    if r == "Killer" then return killerColor end
    if r == "Survivor" then return survivorColor end
    return unknownColor
end

