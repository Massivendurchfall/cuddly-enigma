end

local function collectGiftsOnce()
    local gameFolder=Workspace:FindFirstChild("Game")
    if not gameFolder then return end
    local pof=gameFolder:FindFirstChild("PlaceObjectFolder")
    if not pof then return end
    for _,box in ipairs(pof:GetChildren()) do
        if box.Name=="MouseGiftBox" then
            local collide=box:FindFirstChild("Collide")
            if collide and collide:IsA("BasePart") and collide:FindFirstChildOfClass("TouchTransmitter") then
                tryTouch(collide)
            end
        end
    end
end

local lastJoinSignature=nil
local cachedJoinBtn=nil
local cachedJoinLabel=nil
local nextScanAt=0
local joinDebounceUntil=0

local function str(s)
    if typeof(s)~="string" then return "" end
    return string.lower((s:gsub("%s+"," ")))
end
local function isJoinText(t)
    t=str(t)
    if t=="" then return false end
    return t:find("join") or t:find("current match") or t:find("adventure is in progress") or t:find("beitreten") or t:find("spiel beitreten") or t:find("match beitreten")
end
local function visibleDeep(o)
    if not o or not o.Parent then return false end
    local cur=o
    while cur and cur~=o.Parent and cur~=game do
        if cur:IsA("GuiObject") and cur.Visible==false then return false end
        cur=cur.Parent
    end
    return true
end
local function centerPos(gui)
    local p=gui.AbsolutePosition
    local s=gui.AbsoluteSize
    return Vector2.new(p.X+s.X/2,p.Y+s.Y/2)
end
local function scoreButton(btn)
    if not btn or not btn.Parent then return -1 end
    if not visibleDeep(btn) then return -1 end
    local score=0
    if btn:IsA("TextButton") then
        score=score+2
        if isJoinText(btn.Text) then score=score+6 end
    elseif btn:IsA("ImageButton") then
        score=score+1
    end
    local lab=btn:FindFirstChildWhichIsA("TextLabel",true)
    if lab and isJoinText(lab.Text) then score=score+5 end
    if string.lower(btn.Name)=="joinbtn" then score=score+5 end
    return score
end
local function joinHeaderVisible()
    local pg=Players.LocalPlayer:FindChild("PlayerGui") or Players.LocalPlayer:FindFirstChild("PlayerGui"); if not pg then return false end
    if cachedJoinLabel and cachedJoinLabel.Parent and visibleDeep(cachedJoinLabel) then return true end
    local best=nil
    for _,d in ipairs(pg:GetDescendants()) do
        if d:IsA("TextLabel") and visibleDeep(d) and isJoinText(d.Text) then best=d break end
    end
    cachedJoinLabel=best
    return best~=nil
end
local function findJoinButtonSmart()
    local pg=Players.LocalPlayer:FindFirstChild("PlayerGui"); if not pg then return nil end
    local bestBtn=nil
    local bestScore=-1
    for _,d in ipairs(pg:GetDescendants()) do
        if (d:IsA("TextButton") or d:IsA("ImageButton")) and visibleDeep(d) then
            local sc=scoreButton(d)
            if sc>bestScore then bestScore=sc bestBtn=d end
        end
    end
    if not bestBtn then return nil end
    return bestBtn
end
local function fires(btn,ev)
    if not btn then return end
    if firesignal then pcall(function() firesignal(btn[ev],btn) end) end
end
local function robustClick(btn)
    if not btn or not btn.Parent then return end
    local pos=centerPos(btn)
    pcall(function() btn:Activate() end)
    fires(btn,"MouseButton1Down")
    fires(btn,"Activated")
    VirtualInputManager:SendMouseButtonEvent(pos.X,pos.Y,0,true,game,0)
    task.wait(0.03)
    fires(btn,"MouseButton1Up")
    fires(btn,"MouseButton1Click")
    VirtualInputManager:SendMouseButtonEvent(pos.X,pos.Y,0,false,game,0)
end
local function buttonIsTopMostAtCenter(btn)
    if not btn or not btn.Parent then return false end
    local pos=centerPos(btn)
    local arr=GuiService:GetGuiObjectsAtPosition(pos.X,pos.Y)
    if not arr or #arr==0 then return true end
    for _,o in ipairs(arr) do
        if o==btn or o:IsDescendantOf(btn) then return true end
        if o.Active and o.Visible then return o==btn end
    end
    return false
end
local function clickJoinButton()
    if not autoJoinGUI then return end
    local t=time()
    if t<joinDebounceUntil then return end
    if t<nextScanAt then
        if cachedJoinBtn and cachedJoinBtn.Parent and visibleDeep(cachedJoinBtn) and joinHeaderVisible() then
            local sig=tostring(cachedJoinBtn:GetDebugId())..":"..tostring(cachedJoinBtn.AbsolutePosition)..":"..tostring(cachedJoinBtn.AbsoluteSize)
            if sig~=lastJoinSignature or not buttonIsTopMostAtCenter(cachedJoinBtn) then
                lastJoinSignature=sig
                robustClick(cachedJoinBtn)
                joinDebounceUntil=t+0.6
            end
        end
        return
    end
    nextScanAt=t+1.0
    if not joinHeaderVisible() then return end
    cachedJoinBtn=findJoinButtonSmart()
    if cachedJoinBtn and visibleDeep(cachedJoinBtn) then
        local sig=tostring(cachedJoinBtn:GetDebugId())..":"..tostring(cachedJoinBtn.AbsolutePosition)..":"..tostring(cachedJoinBtn.AbsoluteSize)
        if sig~=lastJoinSignature or not buttonIsTopMostAtCenter(cachedJoinBtn) then
            lastJoinSignature=sig
            robustClick(cachedJoinBtn)
            joinDebounceUntil=time()+0.6
        end
    end
end

